{
  "name": "yourname/woo-elementor-addon",
  "description": "WooCommerce AJAX-powered Elementor product widgets",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "psr-4": {
      "PW\\": "src/"
    }
  },
  "require-dev": {
    "php-stubs/wordpress-stubs": "^6.8",
    "php-stubs/woocommerce-stubs": "^10.6",
    "php-stubs/acf-pro-stubs": "^6.5",
    "arifpavel/elementor-stubs": "3.1.4.1",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.9",
    "phpcompatibility/php-compatibility": "^9.3",
    "php-stubs/woocommerce-subscriptions-stubs": "^8.4"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.0.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
